<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { width:1200px; height:630px; overflow:hidden; background:#0a1628; }
</style>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <radialGradient id="glowGreen" cx="25%" cy="35%" r="45%">
      <stop offset="0%" stop-color="#00FF9D" stop-opacity="0.13"/>
      <stop offset="100%" stop-color="#00FF9D" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="glowRed" cx="80%" cy="72%" r="40%">
      <stop offset="0%" stop-color="#E8341C" stop-opacity="0.10"/>
      <stop offset="100%" stop-color="#E8341C" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="#0a1628"/>
  <rect width="1200" height="630" fill="url(#glowGreen)"/>
  <rect width="1200" height="630" fill="url(#glowRed)"/>

  <!-- Subtle grid -->
  <g stroke="#00FF9D" stroke-width="0.5" opacity="0.05">
    <line x1="0" y1="126" x2="1200" y2="126"/>
    <line x1="0" y1="252" x2="1200" y2="252"/>
    <line x1="0" y1="378" x2="1200" y2="378"/>
    <line x1="0" y1="504" x2="1200" y2="504"/>
    <line x1="240" y1="0" x2="240" y2="630"/>
    <line x1="480" y1="0" x2="480" y2="630"/>
    <line x1="720" y1="0" x2="720" y2="630"/>
    <line x1="960" y1="0" x2="960" y2="630"/>
  </g>

  <!-- Top border accent -->
  <rect x="0" y="0" width="1200" height="4" fill="#00FF9D" opacity="0.8"/>

  <!-- Bottom border accent -->
  <rect x="0" y="626" width="1200" height="4" fill="#00FF9D" opacity="0.25"/>

  <!-- House icon — left side, large -->
  <g transform="translate(82, 170) scale(5.2)">
    <polyline points="4,22 23,5 38,19" fill="none" stroke="#00FF9D" stroke-width="2.8" stroke-linejoin="round" stroke-linecap="round"/>
    <polyline points="38,19 42,22" fill="none" stroke="#E8341C" stroke-width="2.2" stroke-linecap="round" opacity="0.9"/>
    <line x1="8" y1="22" x2="8" y2="40" stroke="#00FF9D" stroke-width="2.8" stroke-linecap="round"/>
    <line x1="38" y1="22" x2="38" y2="32" stroke="#00FF9D" stroke-width="2.8" stroke-linecap="round" opacity="0.7"/>
    <polyline points="38,32 41,37 37,40" fill="none" stroke="#00FF9D" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
    <line x1="8" y1="40" x2="37" y2="40" stroke="#00FF9D" stroke-width="2.8" stroke-linecap="round"/>
    <line x1="14" y1="27" x2="32" y2="27" stroke="#00FF9D" stroke-width="1.5" opacity="0.55"/>
    <line x1="14" y1="33" x2="32" y2="33" stroke="#00FF9D" stroke-width="1.5" opacity="0.55"/>
    <line x1="20" y1="27" x2="20" y2="33" stroke="#00FF9D" stroke-width="1.5" opacity="0.55"/>
    <line x1="26" y1="27" x2="26" y2="33" stroke="#00FF9D" stroke-width="1.5" opacity="0.55"/>
    <circle cx="20" cy="27" r="2.2" fill="#00FF9D"/>
    <circle cx="26" cy="27" r="2.2" fill="#00FF9D"/>
    <circle cx="23" cy="30" r="3" fill="#0a1628" stroke="#00FF9D" stroke-width="1.8"/>
    <circle cx="23" cy="30" r="1.2" fill="#00FF9D"/>
    <rect x="4" y="23.5" width="38" height="2" fill="#E8341C" opacity="0.18"/>
  </g>

  <!-- Vertical divider -->
  <line x1="380" y1="60" x2="380" y2="570" stroke="#00FF9D" stroke-width="1" opacity="0.12"/>

  <!-- Right side — wordmark -->
  <!-- GET OFF -->
  <text
    x="440" y="270"
    font-family="'Bebas Neue', 'Arial Black', sans-serif"
    font-size="148"
    letter-spacing="8"
    fill="white"
    opacity="0.97">GET OFF</text>

  <!-- ZILLOW with strikethrough -->
  <text
    x="440" y="400"
    font-family="'Bebas Neue', 'Arial Black', sans-serif"
    font-size="148"
    letter-spacing="8"
    fill="white"
    opacity="0.28">ZILLOW</text>
  <!-- Red strike -->
  <rect x="438" y="345" width="630" height="10" fill="#E8341C" opacity="0.85" rx="2"/>
  <!-- Red X -->
  <text
    x="1090" y="400"
    font-family="'Bebas Neue', 'Arial Black', sans-serif"
    font-size="110"
    fill="#E8341C"
    opacity="0.9">✕</text>

  <!-- AI badge -->
  <polygon points="440,418 548,418 556,440 448,440" fill="#00FF9D"/>
  <text
    x="498" y="436"
    text-anchor="middle"
    font-family="'Bebas Neue', 'Arial Black', sans-serif"
    font-size="22"
    letter-spacing="5"
    fill="#0a1628">AI</text>

  <!-- Tagline -->
  <text
    x="440" y="490"
    font-family="'Space Mono', monospace"
    font-size="18"
    letter-spacing="3"
    fill="white"
    opacity="0.38">REAL ESTATE WITHOUT THE EXTRACTION</text>

  <!-- Bottom left — domain -->
  <text
    x="86" y="580"
    font-family="'Space Mono', monospace"
    font-size="16"
    letter-spacing="2"
    fill="#00FF9D"
    opacity="0.55">getoffzillow.com</text>

  <!-- Bottom right — fee callout -->
  <text
    x="1114" y="556"
    text-anchor="end"
    font-family="'Bebas Neue', 'Arial Black', sans-serif"
    font-size="52"
    fill="#00FF9D"
    opacity="0.9">3%</text>
  <text
    x="1114" y="580"
    text-anchor="end"
    font-family="'Space Mono', monospace"
    font-size="13"
    letter-spacing="1"
    fill="white"
    opacity="0.35">AT CLOSING ONLY</text>

</svg>
</body>
</html>
